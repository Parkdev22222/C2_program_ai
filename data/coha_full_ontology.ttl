:ThreatLevel_RED rdfs:label "ThreatLevel_RED" .
:ForceProtection rdfs:label "ForceProtection" .
:armedEscort rdfs:label "armedEscort" .

:ThreatLevel_RED rdfs:subClassOf :ThreatLevel .
:ThreatLevel_RED owl:equivalentClass [
    a owl:Restriction ;
    owl:onProperty :triggers ;
    owl:someValuesFrom :ForceProtection
] .

:ForceProtection owl:equivalentClass [
    a owl:Restriction ;
    owl:onProperty :requires ;
    owl:someValuesFrom :armedEscort
] .


# ============================================================
# C2 군사 AI 시스템 — 환경변수 템플릿
# ------------------------------------------------------------
# 사용법:  cp .env.example .env   후 값을 채워 넣으세요.
#   - .env 는 .gitignore 에 포함되어 커밋되지 않습니다(비밀정보 보호).
#   - main.py 실행 시 python-dotenv 가 이 값을 자동 로드합니다.
#   - 이미 셸에 export 된 환경변수가 우선합니다(.env 는 덮어쓰지 않음).
# 모든 변수는 선택 사항이며, 미설정 시 아래 "기본값"으로 동작합니다.
# ============================================================

# ── 에이전트 백엔드 ─────────────────────────────────────────
# langgraph(기본, LangGraph StateGraph) | smolagents(CodeAgent)
C2_AGENT_BACKEND=langgraph

# ── LLM 프로바이더 ─────────────────────────────────────────
# vllm(기본, 직접 서빙한 EXAONE4) | gemini(Google Gemini API)
C2_LLM_PROVIDER=vllm

# vLLM(EXAONE4) OpenAI 호환 엔드포인트. 미설정 시 config/models_config.yaml
# 의 serving.host/port(기본 http://127.0.0.1:8000/v1)를 사용합니다.
C2_AGENT_VLLM_BASE_URL=http://127.0.0.1:8000/v1

# Gemini 사용 시(C2_LLM_PROVIDER=gemini)에만 필요. 둘 중 하나에 발급 키를 넣으세요.
# https://aistudio.google.com/apikey  — 코드/설정이 아닌 여기에만 넣습니다.
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# ── 전술채팅 대화 저장소 (PostgreSQL) ──────────────────────
# postgres | inmemory 강제 선택. 미설정 시 접속정보가 있으면 postgres, 없으면 in-memory.
C2_CHAT_STORE=
# 대화 세션 ID (기본 wargame_chat)
C2_CHAT_SESSION_ID=wargame_chat
# 한 줄 DSN 으로 지정하거나(우선), 아래 분리 변수로 지정합니다.
# C2_PG_DSN=postgresql://postgres:c2password@127.0.0.1:5432/c2
C2_PG_HOST=127.0.0.1
C2_PG_PORT=5432
C2_PG_DB=c2
C2_PG_USER=postgres
C2_PG_PASSWORD=

# ── Neo4j 온톨로지 지식그래프 (Graph RAG) ──────────────────
# OI_NEO4J_URI 미설정 시 in-memory 그래프 스토어로 폴백합니다.
OI_NEO4J_URI=bolt://127.0.0.1:7687
OI_NEO4J_USER=neo4j
OI_NEO4J_PASSWORD=
